# Verified Vallarta™ — Frontend Environment Variables
# Copy this file to .env.local and fill in values. NEVER commit .env.local.

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API (Hono on Railway)
VITE_API_URL=http://localhost:8000

# =============================================================================
# Supabase (Database + Auth + Storage)
# Dashboard: https://supabase.com/dashboard
# =============================================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Vercel (Frontend Deployment)
# Plugin: npx plugins add vercel/vercel-plugin
# =============================================================================
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# =============================================================================
# Coolify VPS (Backend — 31.220.58.212)
# =============================================================================
COOLIFY_URL=http://31.220.58.212:8000
COOLIFY_API_KEY=
COOLIFY_SERVICE_UUID=

# =============================================================================
# Hostinger API (DNS + Domain)
# MCP: npx hostinger-api-mcp@latest
# SECURITY: Load from vault. Rotate immediately if exposed.
# =============================================================================
HOSTINGER_API_TOKEN=

# =============================================================================
# GitHub
# =============================================================================
GH_PAT=

# =============================================================================
# App Configuration
# =============================================================================
VITE_APP_ENV=development
