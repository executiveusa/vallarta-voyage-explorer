  "approved_patterns": [
    "Bento Grid: 2-4 different-sized cards for feature highlights",
    "Asymmetric 2-column zig-zag for content sections",
    "Horizontal scroll carousel for tours/hotels",
    "Infinite scroll with pagination fallback for accessibility",
    "Staggered list animation (animation-delay cascade)",
    "Blur-in reveal for hero text",
    "Live status badge (pulse) for availability indicators",
